# Personal AI OS - Environment Configuration

# LLM Provider: 'openai', 'gemini', or 'ollama'
LLM_PROVIDER=ollama

# LLM Model Selections
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash
OLLAMA_MODEL=hf.co/bartowski/Llama-3.2-1B-Instruct-GGUF:latest
OLLAMA_BASE_URL=http://localhost:11434

# API Keys (Provide based on your LLM_PROVIDER choice)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Local Data Storage
DATABASE_PATH=data/personal_brain.db
FAISS_INDEX_PATH=data/faiss_index

# Logging Level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
